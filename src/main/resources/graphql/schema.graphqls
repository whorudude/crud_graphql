type Coffee {
    id: ID!
    name: String
    size: Size
}

enum Size {
    SHORT, TALL, GRANDE, VENTI
}

type Query {
    findAll: [Coffee]!
    findOne(id: ID): Coffee
}

type Mutation {
    createCoffee(name: String!, size: Size!): Coffee!
    deleteOne(id: ID!): Coffee!
    updateCoffee(id: ID, name: String!, size: Size!): Coffee!
}